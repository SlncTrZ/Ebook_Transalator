# Auto-detect text files, ensure LF normalization
* text=auto

# Python
*.py text diff=python

# Markdown
*.md text

# JSON/YAML/TOML
*.json text
*.yaml text
*.yml text
*.toml text

# Shell scripts
*.sh text eol=lf

# Batch/PowerShell
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binaries
*.png binary
*.ico binary
*.icns binary
*.db binary
